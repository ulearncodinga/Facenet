  <property name="styleSheet">
   <string>
/* 主窗口 */
QWidget#Form {
    background-color: #f8f9fa;
}

/* 标题 */
QLabel#label_10 {
    font-size: 24px;
    font-weight: bold;
    color: #2c3e50;
}

/* 普通文字 */
QLabel {
    font-size: 14px;
    color: #2c3e50;
}

/* 分组框 */
QGroupBox {
    font-size: 15px;
    font-weight: bold;
    color: #2c3e50;
    border: 1px solid #dce6f0;
    border-radius: 10px;
    margin-top: 12px;
    background-color: #ffffff;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 8px;
    padding: 0 8px;
}

/* 按钮 */
QPushButton {
    background-color: #409eff;
    color: white;
    border: none;
    border-radius: 6px;
    padding: 8px 12px;
    font-size: 14px;
}
QPushButton:hover {
    background-color: #66b1ff;
}
QPushButton:pressed {
    background-color: #337ecc;
}

/* 输入框 */
QLineEdit, QPlainTextEdit {
    background-color: #ffffff;
    border: 1px solid #dcdfe6;
    border-radius: 6px;
    padding: 6px 8px;
    font-size: 14px;
    color: #2c3e50;
}
QLineEdit:focus, QPlainTextEdit:focus {
    border: 1px solid #409eff;
}

/* 单选框 */
QRadioButton {
    font-size: 14px;
    color: #2c3e50;
}

/* 表格 */
QTableView {
    background-color: white;
    border: 1px solid #dce6f0;
    border-radius: 8px;
    gridline-color: #e4e7ed;
}
QHeaderView::section {
    background-color: #e8f3ff;
    color: #2c3e50;
    border: none;
    padding: 6px;
}

/* 图片展示框 */
QLabel#label_3, QLabel#label_8, QLabel#label_11 {
    background-color: #ffffff;
    border: 1px dashed #c0c4cc;
    border-radius: 8px;
}

/* 面板 */
QFrame {
    background-color: #ffffff;
    border: 1px solid #e4e7ed;
    border-radius: 10px;
}
